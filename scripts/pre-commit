#!/usr/bin/env bash
set -euo pipefail
REPO_ROOT="$(git rev-parse --show-toplevel)"
PACKAGE_DIR="$REPO_ROOT/BuchstabenNative"
CHANGED=$(git diff --cached --name-only | grep -E "^BuchstabenNative/.*\.swift$|^BuchstabenNative/Package\.swift" || true)
if [ -z "$CHANGED" ]; then exit 0; fi
echo "🔍 Swift files changed — running pre-commit tests..."
cd "$PACKAGE_DIR"
if ! swift build --build-tests -Xswiftc -strict-concurrency=complete 2>&1; then
    echo "❌ Build failed. Commit blocked. Fix errors above, then commit again."
    exit 1
fi
if ! swift test --parallel 2>&1; then
    echo "❌ Tests failed. Commit blocked. Fix above, then commit again."
    echo "   Emergency bypass: git commit --no-verify"
    exit 1
fi
echo "✅ Pre-commit tests passed."
